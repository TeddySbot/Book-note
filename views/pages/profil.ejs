<!DOCTYPE html>
<html lang="fr">
<head>
    <title>Profil</title>
    <%- include('../partials/head') %>

</head>
<body>
    <%- include('../partials/header') %>

<div class="profile-container">

    <h1>Profil utilisateur</h1>

    <div class="profile-header">
        <img src="<%= user.picture || '/images/default-avatar.png' %>" alt="Avatar" class="avatar">
        <div>
            <h2><%= user.name %></h2>
            <p><%= user.email %></p>
        </div>
    </div>

    <ul class="profile-details">
        <li><strong>Langue :</strong> <%= user.locale %></li>
    </ul>

    <a href="/logout" class="btn-logout">Se déconnecter</a>

</div>

</body>

</html>
