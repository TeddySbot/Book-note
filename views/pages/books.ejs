<!DOCTYPE html>
<html lang="fr">
<head>
    <title>Book Note</title>
    <%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/header') %>

<div class="book-container">

    <!-- Titre -->
    <h1><%= book.title %></h1>

    <!-- Statut + couverture (float right) -->
    <% if (user) { %>
        <%
            const statusConfig = {
                wishlist:  { label: '📑 À voir',    css: 'wishlist-badge'  },
                reading:   { label: '📖 En cours',  css: 'reading-badge'   },
                completed: { label: '✅ Terminé',   css: 'completed-badge' },
                favorite:  { label: '❤️ Favori',    css: 'favorite-badge'  },
            };
            const current = currentStatus ? statusConfig[currentStatus] : null;
        %>
        <div class="book-status-block">

            <% if (current) { %>
                <div class="current-status">
                    <span class="status-label">Statut actuel :</span>
                    <span class="status-badge <%= current.css %>"><%= current.label %></span>
                </div>
            <% } %>

            <label for="bookStatus"><%= current ? 'Modifier le statut' : 'Ajouter à ma collection' %> :</label>
            <select id="bookStatus" data-book-id="<%= book.key %>">
                <option value="">-- Choisir un statut --</option>
                <option value="wishlist"  <%= currentStatus === 'wishlist'  ? 'selected' : '' %>>📑 À voir</option>
                <option value="reading"   <%= currentStatus === 'reading'   ? 'selected' : '' %>>📖 En cours de lecture</option>
                <option value="completed" <%= currentStatus === 'completed' ? 'selected' : '' %>>✅ Terminé</option>
                <option value="favorite"  <%= currentStatus === 'favorite'  ? 'selected' : '' %>>❤️ Favori</option>
            </select>

            <% if (currentStatus) { %>
                <button id="removeStatus" data-book-id="<%= book.key %>" class="btn-remove-status">
                    Retirer de ma collection
                </button>
            <% } %>

        </div>
    <% } %>

    <!-- Couverture (float right) -->
    <% if (coverUrl) { %>
        <img class="book-cover" src="<%= coverUrl %>" alt="Couverture du livre">
    <% } else { %>
        <div class="no-cover-placeholder">Aucune image disponible.</div>
    <% } %>

    <!-- Description -->
    <h2>Description</h2>
    <p>
        <% if (book.description) { %>
            <% if (typeof book.description === 'string') { %>
                <%= book.description %>
            <% } else { %>
                <%= book.description.value %>
            <% } %>
        <% } else { %>
            Aucune description disponible.
        <% } %>
    </p>

    <!-- Auteur(s) -->
    <h2>Auteur(s)</h2>
    <% if (authors && authors.length > 0) { %>
    <ul>
        <% authors.forEach(authorName => { %>
            <li><%= authorName %></li>
        <% }) %>
    </ul>
    <% } else { %>
        <p>Auteur inconnu</p>
    <% } %>

    <!-- Sujets -->
    <h2>Sujets</h2>
    <% if (book.subjects && book.subjects.length > 0) { %>
        <ul>
            <% book.subjects.forEach(subject => { %>
                <li><%= subject %></li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>Aucun sujet trouvé.</p>
    <% } %>

    <!-- Lieux -->
    <% if (book.subject_places) { %>
        <h2>Lieux</h2>
        <ul>
            <% book.subject_places.forEach(place => { %>
                <li><%= place %></li>
            <% }) %>
        </ul>
    <% } %>

    <!-- Époques -->
    <% if (book.subject_times) { %>
        <h2>Périodes</h2>
        <ul>
            <% book.subject_times.forEach(time => { %>
                <li><%= time %></li>
            <% }) %>
        </ul>
    <% } %>

</div>

<%- include('../partials/footer') %>

<script src="/js/books.js"></script>

</body>
</html>
